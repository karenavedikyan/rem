{
  "version": 2,
  "redirects": [
    { "source": "/partner/login", "destination": "/partner/login/", "permanent": false },
    {
      "source": "/partner/cabinet",
      "destination": "/partner/cabinet/",
      "permanent": false
    },
    {
      "source": "/catalog/service",
      "destination": "/catalog/service/",
      "permanent": false
    },
    {
      "source": "/catalog/services/:id",
      "destination": "/catalog/service/?id=:id",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/api/auth/:action", "destination": "/api/auth?action=:action" },
    {
      "source": "/api/catalog/services/:id/reviews",
      "destination": "/api/catalog/service-reviews?serviceId=:id"
    },
    {
      "source": "/api/catalog/services/:id",
      "destination": "/api/catalog/service-by-id?serviceId=:id"
    }
  ]
}
