{
  "ci": {
    "collect": {
      "numberOfRuns": 2,
      "url": [
        "https://rem-navy.vercel.app/",
        "https://rem-navy.vercel.app/navigator/",
        "https://rem-navy.vercel.app/catalog/",
        "https://rem-navy.vercel.app/contacts/"
      ],
      "settings": {
        "onlyCategories": [
          "performance",
          "accessibility",
          "best-practices",
          "seo"
        ],
        "emulatedFormFactor": "mobile"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "warn",
          {
            "minScore": 0.55
          }
        ],
        "categories:accessibility": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "categories:best-practices": [
          "error",
          {
            "minScore": 0.8
          }
        ],
        "categories:seo": [
          "error",
          {
            "minScore": 0.85
          }
        ]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
