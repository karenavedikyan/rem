generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PartnerType {
  MASTER
  COMPANY
  STORE
}

enum ServiceStage {
  PLANNING
  ROUGH
  ENGINEERING
  FINISHING
  FURNITURE
}

enum ServiceTaskType {
  SANUZEL
  KITCHEN
  ELECTRICAL
  PLUMBING
  TILING
  PAINTING
  FLOORING
  WINDOWS
  DESIGN
  GENERAL
}

model Partner {
  id              String      @id @default(uuid()) @db.Uuid
  type            PartnerType
  name            String
  description     String?
  promotionBannerUrl String?
  promotionIds    String[]    @default([])
  city            String      @default("Краснодар")
  areas           String[]    @default([])
  specializations String[]    @default([])
  isApproved      Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  services        Service[]
  account         PartnerAccount?

  @@index([isApproved, city])
  @@index([type])
}

model PartnerAccount {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String
  partnerId    String   @unique @db.Uuid
  partner      Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Service {
  id          String          @id @default(uuid()) @db.Uuid
  partnerId   String          @db.Uuid
  partner     Partner         @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  reviews     ServiceReview[]
  title       String
  description String?
  imageUrl    String?
  stage       ServiceStage
  taskType    ServiceTaskType
  minPrice    Int?
  maxPrice    Int?
  currency    String          @default("RUB")
  city        String          @default("Краснодар")
  areas       String[]        @default([])
  isActive    Boolean         @default(true)
  rating      Float?
  ratingCount Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([partnerId])
  @@index([isActive, stage, city, taskType])
}

model ServiceReview {
  id         String   @id @default(uuid()) @db.Uuid
  serviceId  String   @db.Uuid
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  rating     Int
  comment    String?
  authorName String?
  createdAt  DateTime @default(now())

  @@index([serviceId, createdAt])
}

model Request {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  phone        String
  stage        String?
  objectType   String?
  comment      String?
  serviceId    String?
  serviceTitle String?
  source       String   @default("direct")
  createdAt    DateTime @default(now())

  @@index([createdAt])
}
